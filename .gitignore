```gitignore
# ======================
# Environment Variables
# ======================
.env
*.env

# ======================
# Python Cache
# ======================
__pycache__/
*.py[cod]
*$py.class

# Ignore cache everywhere
**/__pycache__/
src/__pycache__/

# ======================
# Virtual Environment
# ======================
venv/
.venv/
env/

# ======================
# Generated Outputs
# ======================
images/
*.md
outputs/

# Keep README.md tracked
!readme.md
!README.md

# Ignore generated blogs only
Test Blog.md
Inside a Transformer From Attention to Out*.md
State of Multimodal LLMs in 2026.md
understanding_self_attention_in_deep_lear*.md
unlocking_the_power_of_self_attention.md

# ======================
# Jupyter / Notebook
# ======================
.ipynb_checkpoints/

# ======================
# IDE Files
# ======================
.vscode/
.idea/

# ======================
# OS Files
# ======================
.DS_Store
Thumbs.db

# ======================
# Logs
# ======================
*.log

# ======================
# Local temporary files
# ======================
tmp/
temp/
```
